<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.bugstack.ai.infrastructure.dao.ChatMessageMapper">

    <resultMap id="BaseMap" type="cn.bugstack.ai.infrastructure.dao.po.ChatMessagePO">
        <id column="id" property="id"/>
        <result column="conversation_id" property="conversationId"/>
        <result column="role" property="role"/>
        <result column="content" property="content"/>
        <result column="metadata" property="metadata"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="cn.bugstack.ai.infrastructure.dao.po.ChatMessagePO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_message (conversation_id, role, content, metadata, created_at)
        VALUES (#{conversationId}, #{role}, #{content}, #{metadata}::jsonb, #{createdAt})
    </insert>

    <select id="selectByConversationId" parameterType="java.lang.Long" resultMap="BaseMap">
        SELECT id, conversation_id, role, content, metadata, created_at
        FROM chat_message
        WHERE conversation_id = #{conversationId}
        ORDER BY created_at ASC
    </select>

    <delete id="deleteByConversationId" parameterType="java.lang.Long">
        DELETE FROM chat_message WHERE conversation_id = #{conversationId}
    </delete>

</mapper>
